1. Palindrome Number
-> 

//Input - 121
//Output - True
//Input - 346
//Output - False

using System;

public class CheckIntPalindrome
{
    public static void CheckPalindrome(int num)
    {
        int orignalnum = num;
        int reversed = 0;
        
        for(;num>0;num=num/10)
        {
            int digit = num % 10;
            reversed = reversed * 10 + digit;
        }
        
        Console.WriteLine(reversed == orignalnum); 
    }

    public static void Main()
    {
        CheckPalindrome(121);
        CheckPalindrome(346);
    }
}

2. Palindrome String

//Input - MADAM
//Output - True
//Input - CAR
//Output - False

using System;

public class StringPalindrome
{
    public static void Palindrome(string input)
    {
        bool status = true;
        
        for(int i = 0; i<input.Length/2;i++)
        {
            if(input[i] != input[input.Length-1-i])
            {
                status=false;
                break;
            }
        }
        
        Console.WriteLine(status);
        
    }
    
    public static void Main()
    {
        Palindrome("MADAM");
        Palindrome("CAR");
    }
}
