//Find Missing Number
//Input [1,2,4,5,6,7]
//Output 3


using System;

public class FindMissingNo
{
    private void FindMissing(int[] arr)
    { 
        int n = arr.Length+1;  
        int expectedsum=(n*(n+1))/2;
        int sumofarr=0;
        
        foreach(int d in arr)
        {
            sumofarr=sumofarr+d;
        }
        
        Console.WriteLine(expectedsum-sumofarr);  
    }
    
    public static void Main()
    {
        FindMissingNo r = new FindMissingNo();
        int[] arr = { 1,2,4,5,6,7 };
        r.FindMissing(arr);   
    }
}
