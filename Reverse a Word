//input - i love india
//output - india love i

using System;

public class Reverse
{
    public static void ReverseWord(string input)
    {
        string[] arr = input.Split(' ');
        string output="";
        
        for(int i = arr.Length-1;i>=0;i--)
        {
            if(i==arr.Length-1)
            {
                output=arr[i];
            }
            else{
                output=output+" "+arr[i];
            }
        }
        
        Console.WriteLine(output);
    }
    
    public static void Main()
    {
        ReverseWord("I Love India");
    }
}
