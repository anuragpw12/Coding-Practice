//Reverse A word 
//Input - I love india
//Output - india love I

using System;

public class Reverse
{
    private void ReverseAWord(string input)
    {
        string[] arr = input.Split(' ');
        string output="";
        
        for(int i = arr.Length - 1; i>=0; i--)
        {
            if(i==arr.Length-1)
                output = arr[i];
            else
                output = output + " " + arr[i];
        }
        
        Console.WriteLine(output);
        
    }
    
    public static void Main()
    {
        Reverse r = new Reverse();
        r.ReverseAWord("I Love India");
    }
}
