//String Compression
//Input "aaabbcc"
//Output a3b2c2

using System;
using System.Text;

public class StringCompression
{
    private void Compression(string input)
    {
        // Handle empty or null inputs safely
        if (string.IsNullOrEmpty(input)) return;

        StringBuilder s = new StringBuilder();
        int count = 1;

        for (int i = 0; i < input.Length; i++)
        {
            // If the next character is the same, increment the count
            if (i + 1 < input.Length && input[i] == input[i + 1])
            {
                count++;
            }
            else
            {
                // Character has changed or we reached the end of the string
                s.Append(input[i]);
                s.Append(count);
                count = 1; // Reset counter for the next new character
            }
        }

        Console.WriteLine(s.ToString());        
    }
    
    public static void Main()
    {
        StringCompression r = new StringCompression();
        
        r.Compression("aaabbcc");   // Output: a3b2c2
        r.Compression("aaabbccd");  // Output: a3b2c2d1 (Your old code would fail here)
    }
}
